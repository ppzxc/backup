FROM alpine:3.19

RUN apk add --no-cache \
    ca-certificates \
    curl \
    bash \
    restic \
    rclone \
    mariadb-client \
    postgresql16-client \
    chrony \
    shadow

# Copy compiled backup binary into container
COPY target/debug/backup /usr/local/bin/backup
RUN chmod +x /usr/local/bin/backup

CMD ["backup", "--help"]
